{
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 4,
    "files.associations": {
        "*.js": "javascript"
    },
    "eslint.validate": [
        "javascript",
        "typescript"
    ],
    "terminal.integrated.defaultProfile.linux": "bash",
    "files.exclude": {
        "**/node_modules": true,
        "**/.git": true
    }
}
